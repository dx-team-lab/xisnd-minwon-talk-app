rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isManager() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'manager')
      );
    }

    // ✅ 기존 규칙 (유지)
    match /{path=**}/siteImages/{imageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }
    
    match /{path=**}/complaints/{complaintId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_manager/{managerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager(); 
    }

    match /responseGuides/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /caseExamples/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /actionPlanLinks/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /sites/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /references/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isManager();
      allow update, delete: if false; 
    }

    // 🌟 문의(inquiries) 규칙 - 단순화 버전
    match /inquiries/{inquiryId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isManager() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
