# =============================================================
# .env.example - 이 파일을 복사해서 .env 파일로 만들고
# 아래 값들을 실제 DB 정보로 채워주세요.
# .env 파일은 절대 Git에 올리지 마세요!
# =============================================================

# MySQL 접속 정보
# DB_URL: MySQL 서버 주소와 데이터베이스 이름 (기본값: localhost:3306/minwon_platform)
DB_URL=jdbc:mysql://localhost:3306/minwon_platform?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# DB_USERNAME: MySQL 계정 이름 (예: root)
DB_USERNAME=여기에_DB_계정명_입력

# DB_PASSWORD: MySQL 비밀번호
DB_PASSWORD=여기에_DB_비밀번호_입력

# 서버 포트 (기본값: 8080, 변경 원하면 숫자 수정)
SERVER_PORT=8080
