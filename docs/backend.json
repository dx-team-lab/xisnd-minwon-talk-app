
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the Minwon Community application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role", "createdAt"]
    },
    "ResponseGuide": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ResponseGuide",
      "type": "object",
      "description": "시스템 설정에서 관리하는 대응 방안 가이드",
      "properties": {
        "id": { "type": "string" },
        "region": { "type": "string", "enum": ["주거지역", "상업지역", "공업지역", "혼합지역"] },
        "phase": { "type": "string", "enum": ["착수전", "철거", "토공", "골조", "마감", "준공이후"] },
        "type": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["소음", "비산먼지", "진동", "교통", "언론", "파손", "폐기물", "야간의혹", "영업피해", "출입통제"] } 
        },
        "cause": { "type": "string" },
        "action": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["region", "phase", "type", "cause", "action"]
    },
    "CaseExample": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CaseExample",
      "type": "object",
      "description": "시스템 설정에서 관리하는 보상 사례",
      "properties": {
        "id": { "type": "string" },
        "region": { "type": "string", "enum": ["주거지역", "상업지역", "공업지역", "혼합지역"] },
        "phase": { "type": "string", "enum": ["착수전", "철거", "토공", "골조", "마감", "준공이후"] },
        "type": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["소음", "비산먼지", "진동", "교통", "언론", "파손", "폐기물", "야간의혹", "영업피해", "출입통제"] } 
        },
        "complainant": { "type": "string" },
        "requestType": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["정신적피해보상", "영업피해보상", "재산피해보상", "분쟁조정", "대인피해보상", "행정처분"] } 
        },
        "compensationStatus": { "type": "string" },
        "compensationAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["region", "phase", "type", "complainant", "requestType", "compensationStatus"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "role",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Admin privileges"
        }
      },
      {
        "path": "/roles_manager/{managerId}",
        "definition": {
          "entityName": "role",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Manager privileges"
        }
      },
      {
        "path": "/responseGuides/{docId}",
        "definition": {
          "entityName": "ResponseGuide",
          "schema": { "$ref": "#/backend/entities/ResponseGuide" },
          "description": "Global response guides managed by admins"
        }
      },
      {
        "path": "/caseExamples/{docId}",
        "definition": {
          "entityName": "CaseExample",
          "schema": { "$ref": "#/backend/entities/CaseExample" },
          "description": "Global case examples managed by admins"
        }
      }
    ]
  }
}
